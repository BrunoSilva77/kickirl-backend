{
  "manifest_version": 3,
  "name": "KickIRL — GPS para Streamers",
  "version": "1.0.0",
  "description": "Compartilhe sua localização ao vivo com viewers da Kick.com",
  "permissions": [
    "storage",
    "offscreen",
    "alarms",
    "geolocation"
  ],
  "host_permissions": [
    "http://localhost:3000/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
